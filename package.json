{
  "name": "creamybits",
  "version": "1.0.0",
  "description": "CreamyBits African Pastries – Albuquerque, NM",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "setupFiles": [],
    "setupFilesAfterEnv": ["./tests/setup.js"],
    "resetMocks": false,
    "moduleNameMapper": {
      "^uuid$": "<rootDir>/tests/__mocks__/uuid.js"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "resend": "^6.9.3",
    "stripe": "^16.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
